{
  "name": "my-pers-fin-bot",
  "version": "0.1.0",
  "description": "Personal Finance Telegram Bot",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist coverage",
    "rebuild": "pnpm run clean && pnpm run build",
    "check": "biome check src && tsc --noEmit",
    "fix": "biome check --write src && tsc --noEmit",
    "format": "biome format --write src",
    "lint": "biome lint src",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --coverageReporters=text-summary --coverageReporters=lcov --ci",
    "validate": "pnpm run check && pnpm run test",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:dev": "pm2 start ecosystem.config.js --env development",
    "pm2:stop": "pm2 stop my-pers-fin-bot",
    "pm2:restart": "pm2 restart my-pers-fin-bot",
    "pm2:delete": "pm2 delete my-pers-fin-bot",
    "deploy": "pnpm run validate && pnpm run build && pnpm run pm2:restart",
    "deploy:quick": "pnpm run build && pnpm run pm2:restart"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@sentry/node": "^8.39.0",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.6.2",
    "bull": "^4.16.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.9.2",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.67.0",
    "reflect-metadata": "^0.2.2",
    "sanitize-html": "^2.17.0",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.28",
    "undici": "^7.18.2",
    "validator": "^13.15.26",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/exceljs": "^1.3.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.30",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.0",
    "@types/sanitize-html": "^2.13.0",
    "@types/validator": "^13.12.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}

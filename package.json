{
  "name": "my-pers-fin-bot",
  "version": "0.1.0",
  "description": "Personal Finance Telegram Bot",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run format:check && pnpm run type-check",
    "check:fix": "pnpm run lint:fix && pnpm run format",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:dev": "pm2 start ecosystem.config.js --env development",
    "pm2:stop": "pm2 stop my-pers-fin-bot",
    "pm2:restart": "pm2 restart my-pers-fin-bot",
    "pm2:delete": "pm2 delete my-pers-fin-bot",
    "pm2:logs": "pm2 logs my-pers-fin-bot",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 status",
    "deploy": "pnpm run build && pnpm run pm2:restart"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.6.2",
    "bull": "^4.16.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.9.2",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.67.0",
    "reflect-metadata": "^0.2.2",
    "sanitize-html": "^2.17.0",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.28",
    "undici": "^7.18.2",
    "validator": "^13.15.26",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/exceljs": "^1.3.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.30",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.0",
    "@types/sanitize-html": "^2.13.0",
    "@types/validator": "^13.12.2",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "eslint": "^9.39.2",
    "globals": "^16.2.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.53.0"
  }
}
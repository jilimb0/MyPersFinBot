{
  "name": "my-pers-fin-bot",
  "version": "0.1.0",
  "description": "Personal Finance Telegram Bot",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "pnpm run build && node dist/index.js",
    "dev:watch": "pnpm run build && sh -c 'tsc -w --preserveWatchOutput & node --watch dist/index.js'",
    "build": "tsc",
    "clean": "rm -rf dist coverage",
    "rebuild": "pnpm run clean && pnpm run build",
    "check": "biome check src && tsc --noEmit",
    "fix": "biome check --write src && tsc --noEmit",
    "format": "biome format --write src",
    "format:check": "biome format --check src",
    "lint": "biome check src",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:stable": "jest --coverage --runInBand",
    "test:ci": "jest --coverage --coverageReporters=text-summary --coverageReporters=lcov --ci",
    "test:e2e": "jest --config jest.e2e.config.js",
    "test:e2e:critical": "jest --config jest.e2e.config.js src/__tests__/integration/critical-flows.e2e.test.ts src/__tests__/integration/expense-flow.e2e.test.ts src/__tests__/integration/income-flow.e2e.test.ts src/__tests__/integration/voice-flow.e2e.test.ts src/__tests__/integration/analytics-flow.e2e.test.ts",
    "test:e2e:premium-gating": "jest src/__tests__/integration/premium-gating.e2e.test.ts --runInBand",
    "test:e2e:ci": "mkdir -p artifacts/test-results && CI=true jest --config jest.e2e.config.js --runInBand --json --outputFile artifacts/test-results/e2e-critical.json src/__tests__/integration/critical-flows.e2e.test.ts src/__tests__/integration/expense-flow.e2e.test.ts src/__tests__/integration/income-flow.e2e.test.ts src/__tests__/integration/voice-flow.e2e.test.ts src/__tests__/integration/analytics-flow.e2e.test.ts",
    "test:integration:real-db": "REAL_DB_TEST=1 jest src/__tests__/integration/real-db.sqlite.integration.test.ts --runInBand",
    "test:integration:real-db:ci": "mkdir -p artifacts/test-results && CI_REAL_DB=true jest src/__tests__/integration/real-db.sqlite.integration.test.ts --runInBand --json --outputFile artifacts/test-results/real-db.json",
    "audit:prod": "node scripts/ops/audit-prod.js",
    "validate": "pnpm run check && pnpm run test",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:dev": "pm2 start ecosystem.config.js --env development",
    "pm2:stop": "pm2 stop my-pers-fin-bot",
    "pm2:restart": "pm2 restart my-pers-fin-bot",
    "pm2:delete": "pm2 delete my-pers-fin-bot",
    "deploy": "pnpm run validate && pnpm run build && pnpm run pm2:restart",
    "deploy:quick": "pnpm run build && pnpm run pm2:restart",
    "docs:generate": "typedoc",
    "docs:serve": "npx serve docs/api",
    "docs:clean": "rm -rf docs/api",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules' '#docs/api'",
    "lint:md:fix": "markdownlint-cli2 --fix '**/*.md' '#node_modules' '#docs/api'",
    "benchmark": "ts-node --transpile-only scripts/benchmarks/index.ts",
    "benchmark:ci": "ts-node --transpile-only scripts/benchmarks/index.ts --json artifacts/benchmarks/summary.json",
    "benchmark:fx": "ts-node --transpile-only scripts/benchmarks/fx.ts",
    "benchmark:db": "ts-node --transpile-only scripts/benchmarks/db.ts",
    "benchmark:nlp": "ts-node --transpile-only scripts/benchmarks/nlp.ts",
    "benchmark:profile:fx": "mkdir -p artifacts/profiles && node --cpu-prof --cpu-prof-dir=artifacts/profiles -r ts-node/register/transpile-only scripts/benchmarks/fx.ts",
    "benchmark:profile:db": "mkdir -p artifacts/profiles && node --cpu-prof --cpu-prof-dir=artifacts/profiles -r ts-node/register/transpile-only scripts/benchmarks/db.ts",
    "benchmark:profile:nlp": "mkdir -p artifacts/profiles && node --cpu-prof --cpu-prof-dir=artifacts/profiles -r ts-node/register/transpile-only scripts/benchmarks/nlp.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@jilimb0/tgwrapper": "^0.10.0",
    "@jilimb0/tgwrapper-adapter-redis": "^0.4.0",
    "@jilimb0/tgwrapper-observability": "^0.5.1",
    "@sentry/node": "^10.45.0",
    "better-sqlite3": "12.8.0",
    "bull": "^4.16.5",
    "dayjs": "^1.11.20",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "fluent-ffmpeg": "^2.1.3",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "reflect-metadata": "^0.2.2",
    "sanitize-html": "^2.17.2",
    "typeorm": "^0.3.28",
    "undici": "^7.24.5",
    "validator": "^13.15.26",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "@types/node-cron": "^3.0.11",
    "@types/sanitize-html": "^2.16.1",
    "@types/validator": "^13.15.10",
    "jest": "^30.2.0",
    "markdownlint-cli2": "^0.21.0",
    "sql.js": "^1.14.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sqlite3"
    ],
    "overrides": {
      "tar": "^7.5.8",
      "lodash": "^4.17.23",
      "diff": "^4.0.4"
    }
  }
}
